{
    "task": [
        {
            "name": "SeizeDeliveryJobs",
            "description": "$task.SeizeDeliveryJobs.description",
            "label": "$task.SeizeDeliveryJobs.label",
            "entry": "SeizeDeliveryJobsMain",
            "option": [
                "SeizeDeliveryJobsCommissionSource"
            ],
            "controller": [
                "Win32-Front",
                "Wlroots"
            ],
            "group": [
                "regional_development"
            ]
        }
    ],
    "option": {
        "SeizeDeliveryJobsCommissionSource": {
            "type": "select",
            "default_case": "WulingCity",
            "label": "$task.SeizeDeliveryJobsCommissionSource.label",
            "cases": [
                {
                    "name": "WulingCity",
                    "label": "$task.SeizeDeliveryJobsCommissionSource.cases.WulingCity.label",
                    "option": [
                        "SeizeDeliveryJobsRewardWulingCity",
                        "SeizeDeliveryJobsPostProcessing",
                        "SeizeDeliveryJobsSpecifyDeliveryPointWulingCity"
                    ]
                },
                {
                    "name": "TestArea",
                    "label": "$task.SeizeDeliveryJobsCommissionSource.cases.TestArea.label",
                    "option": [
                        "SeizeDeliveryJobsRewardTestArea",
                        "SeizeDeliveryJobsPostProcessing",
                        "SeizeDeliveryJobsSpecifyDeliveryPointTestArea"
                    ]
                }
            ]
        },
        "SeizeDeliveryJobsRewardWulingCity": {
            "type": "select",
            "default_case": "Sixteen3",
            "label": "$task.SeizeDeliveryJobsRewardWulingCity.label",
            "cases": [
                {
                    "name": "Sixteen3",
                    "label": "$task.SeizeDeliveryJobsRewardWulingCity.cases.Sixteen3.label"
                },
                {
                    "name": "Sixteen3OrEleven9",
                    "label": "$task.SeizeDeliveryJobsRewardWulingCity.cases.Sixteen3OrEleven9.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsFindTarget": {
                            "any_of": [
                                "__SeizeDeliveryJobsFindTarget16_3",
                                "__SeizeDeliveryJobsFindTarget11_9"
                            ],
                            "focus": {
                                "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.wulingCityOrFound"
                            }
                        }
                    }
                }
            ]
        },
        "SeizeDeliveryJobsRewardTestArea": {
            "type": "select",
            "default_case": "Ten6",
            "label": "$task.SeizeDeliveryJobsRewardTestArea.label",
            "cases": [
                {
                    "name": "Ten6",
                    "label": "$task.SeizeDeliveryJobsRewardTestArea.cases.Ten6.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsFindTarget": {
                            "any_of": [
                                "__SeizeDeliveryJobsFindTarget10_6"
                            ],
                            "focus": {
                                "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.testAreaFound"
                            }
                        }
                    }
                }
            ]
        },
        "SeizeDeliveryJobsPostProcessing": {
            "type": "select",
            "default_case": "Disable",
            "label": "$task.SeizeDeliveryJobsPostProcessing.label",
            "description": "$task.SeizeDeliveryJobsPostProcessing.description",
            "cases": [
                {
                    "name": "Disable",
                    "label": "$task.SeizeDeliveryJobsPostProcessing.cases.Disable.label"
                },
                {
                    "name": "Tele",
                    "label": "$task.SeizeDeliveryJobsPostProcessing.cases.Tele.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsPostProcessingEntry": {
                            "enabled": true
                        },
                        "SeizeDeliveryJobsSuccessTeleportDone": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "TeleWalk",
                    "label": "$task.SeizeDeliveryJobsPostProcessing.cases.TeleWalk.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsPostProcessingEntry": {
                            "enabled": true
                        },
                        "SeizeDeliveryJobsSuccessWalkDone": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "TeleWalkFetch",
                    "label": "$task.SeizeDeliveryJobsPostProcessing.cases.TeleWalkFetch.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsPostProcessingEntry": {
                            "enabled": true
                        },
                        "SeizeDeliveryJobsSuccessFetchGoods": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "TeleWalkFetchDeliver",
                    "label": "$task.SeizeDeliveryJobsPostProcessing.cases.TeleWalkFetchDeliver.label",
                    "option": [
                        "SeizeDeliveryJobsPostDepartureRiskAcknowledgement"
                    ],
                    "pipeline_override": {
                        "SeizeDeliveryJobsPostProcessingEntry": {
                            "enabled": true
                        },
                        "SeizeDeliveryJobsPostDepartureEntry": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "SeizeDeliveryJobsPostDepartureRiskAcknowledgement": {
            "type": "switch",
            "label": "$task.SeizeDeliveryJobsPostDepartureRiskAcknowledgement.label",
            "description": "$task.SeizeDeliveryJobsPostDepartureRiskAcknowledgement.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "No",
                    "pipeline_override": {
                        "SeizeDeliveryJobsGuard": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Yes"
                }
            ]
        },
        "SeizeDeliveryJobsSpecifyDeliveryPointWulingCity": {
            "type": "switch",
            "label": "$task.SeizeDeliveryJobsSpecifyDeliveryPoint.label",
            "cases": [
                {
                    "name": "No"
                },
                {
                    "name": "Yes",
                    "option": [
                        "SeizeDeliveryJobsDeliveryPointWulingCity"
                    ],
                    "pipeline_override": {
                        "SeizeDeliveryJobsFindTarget": {
                            "enabled": false
                        },
                        "SeizeDeliveryJobsScanTarget": {
                            "enabled": true
                        },
                        "SeizeDeliveryJobsEndpointFilterWulingCity": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "SeizeDeliveryJobsSpecifyDeliveryPointTestArea": {
            "type": "switch",
            "label": "$task.SeizeDeliveryJobsSpecifyDeliveryPoint.label",
            "cases": [
                {
                    "name": "No"
                },
                {
                    "name": "Yes",
                    "option": [
                        "SeizeDeliveryJobsDeliveryPointTestArea"
                    ],
                    "pipeline_override": {
                        "SeizeDeliveryJobsFindTarget": {
                            "enabled": false
                        },
                        "SeizeDeliveryJobsScanTarget": {
                            "enabled": true
                        },
                        "SeizeDeliveryJobsEndpointFilterTestArea": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "SeizeDeliveryJobsDeliveryPointWulingCity": {
            "type": "checkbox",
            "label": "$task.SeizeDeliveryJobsDeliveryPoint.label",
            "default_case": [
                "Owl",
                "MaterialResearchInstitute",
                "Observatory",
                "TechProductionOffice"
            ],
            "cases": [
                {
                    "name": "Owl",
                    "label": "$task.SeizeDeliveryJobsDeliveryPointWulingCity.cases.Owl.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsEndpointFilterOwl": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "MaterialResearchInstitute",
                    "label": "$task.SeizeDeliveryJobsDeliveryPointWulingCity.cases.MaterialResearchInstitute.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsEndpointFilterMaterialResearchInstitute": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Observatory",
                    "label": "$task.SeizeDeliveryJobsDeliveryPointWulingCity.cases.Observatory.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsEndpointFilterObservatory": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "TechProductionOffice",
                    "label": "$task.SeizeDeliveryJobsDeliveryPointWulingCity.cases.TechProductionOffice.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsEndpointFilterTechProductionOffice": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "SeizeDeliveryJobsDeliveryPointTestArea": {
            "type": "checkbox",
            "label": "$task.SeizeDeliveryJobsDeliveryPoint.label",
            "default_case": [
                "No1TypeCAnchorArea",
                "No3TypeCAnchorArea",
                "JingweiFieldArea"
            ],
            "cases": [
                {
                    "name": "No1TypeCAnchorArea",
                    "label": "$task.SeizeDeliveryJobsDeliveryPointTestArea.cases.No1TypeCAnchorArea.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsEndpointFilterNo1TypeCAnchorArea": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No3TypeCAnchorArea",
                    "label": "$task.SeizeDeliveryJobsDeliveryPointTestArea.cases.No3TypeCAnchorArea.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsEndpointFilterNo3TypeCAnchorArea": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "JingweiFieldArea",
                    "label": "$task.SeizeDeliveryJobsDeliveryPointTestArea.cases.JingweiFieldArea.label",
                    "pipeline_override": {
                        "SeizeDeliveryJobsEndpointFilterJingweiFieldArea": {
                            "enabled": true
                        }
                    }
                }
            ]
        }
    }
}
