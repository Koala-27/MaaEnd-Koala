    "__ScenePrivateWorldAnyEnterFactory": {
        "desc": "在任意大世界界面，进入工厂模式",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    60,
                    60
                ],
                "template": [
                    "SceneManager/WorldFactoryNotActive.png",
                    "SceneManager/WorldFactoryActive.png"
                ],
                "threshold": 0.9
            }
        },
        "inverse": true,
        "next": [
            "__ScenePrivateMapValleyIVTheHubEnterTeleport",
            "[JumpBack]SceneEnterMapValleyIVTheHub"
        ]
    },
    "__ScenePrivateAnyEnterWorldFactorySuccess": {
        "desc": "从任意界面进入大世界工厂模式成功",
        "recognition": "And",
        "all_of": [
            "InWorldFactory"
        ],
        "pre_delay": 0,
        "post_delay": 0
