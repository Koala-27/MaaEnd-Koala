{
    "__ScenePrivateWorldSpaceExit": {
        "desc": "从大世界协议空间、好友飞船退出",
        "recognition": "TemplateMatch",
        "roi": [
            0,
            0,
            100,
            100
        ],
        "template": [
            "SceneManager/WorldSpaceExit.png",
            "SceneManager/WorldSpaceExit1.png"
        ],
        "pre_wait_freezes": 200,
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "AutoAltClickAction",
        "post_delay": 0,
        "next": [
            "__ScenePrivateWorldSpaceExitConfirm",
            "__ScenePrivateEndVisit"
        ]
    },
    "__ScenePrivateEndVisit": {
        "desc": "识别结束拜访",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    -260,
                    -100,
                    260,
                    100
                ],
                "expected": [
                    "结束拜访",
                    "結束拜訪",
                    "(?i)End\\s*Visit",
                    "訪問終了",
                    "방문 종료"
                ]
            }
        },
        "action": {
            "type": "Click"
        },
        "next": [
            "__ScenePrivateWorldSpaceExitConfirm"
        ]
    },
    "__ScenePrivateWorldSpaceExitConfirm": {
        "desc": "从大世界协议空间、好友飞船退出的确认界面",
        "recognition": "And",
        "all_of": [
            "YellowConfirmButtonType1"
        ],
        "pre_wait_freezes": 200,
        "pre_delay": 0,
        "action": {
            "type": "Click"
        },
        "post_delay": 0
    },
    "__ScenePrivateAnyEnterWorldSuccess": {
        "desc": "从任意界面进入大世界成功",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InWorld"
                ]
            }
        },
        "pre_wait_freezes": {
            "target": [
                70,
                80,
                70,
                60
            ],
            "time": 800,
            "timeout": 2000
        },
        "pre_delay": 0,
        "post_delay": 0
    },
    "__ScenePrivateWorldFactoryDisableEnterFactoryActive": {
        "desc": "在大世界工厂模式不可用，例如战斗状态，进入工厂模式",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    0,
                                    0,
                                    60,
                                    60
                                ],
                                "template": [
                                    "SceneManager/WorldFactoryDisable.png"
                                ]
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    -200,
                                    0,
                                    200,
                                    200
                                ],
                                "template": [
                                    "SceneManager/WorldMenu.png"
                                ],
                                "green_mask": true
                            }
                        }
                    }
                ]
            }
        },
        "next": [
            "__ScenePrivateAnyEnterWorldFactorySuccess",
            "__ScenePrivateWorldFactoryNotActiveEnterFactoryActive",
            "[JumpBack]__ScenePrivateWorldAnyEnterFactory"
        ]
    },
    "__ScenePrivateWorldFactoryNotActiveEnterFactoryActive": {
        "desc": "在大世界工厂模式未激活，进入工厂模式",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    0,
                                    0,
                                    60,
                                    60
                                ],
                                "template": [
                                    "SceneManager/WorldFactoryNotActive.png"
                                ]
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    -200,
                                    0,
                                    200,
                                    200
                                ],
                                "template": [
                                    "SceneManager/WorldMenu.png"
                                ],
                                "green_mask": true
                            }
                        }
                    }
                ],
                "box_index": 0
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "AutoAltClickAction"
            }
        },
        "next": [
            "__ScenePrivateAnyEnterWorldFactorySuccess"
        ]
    },
    "__ScenePrivateWorldDijiangEnterFactoryActive": {
