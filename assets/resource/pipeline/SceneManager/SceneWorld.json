        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    0,
                                    0,
                                    400,
                                    80
                                ],
                                "template": [
                                    "SceneManager/WorldDijiangMenu.png"
                                ],
                                "green_mask": true
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "roi": [
                                    -200,
                                    0,
                                    200,
                                    200
                                ],
                                "template": [
                                    "SceneManager/WorldMenu.png"
                                ],
                                "green_mask": true
                            }
                        }
                    }
