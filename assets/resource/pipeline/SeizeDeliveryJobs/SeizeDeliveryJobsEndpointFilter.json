    "SeizeDeliveryJobsEndpointMatched": {
        "desc": "终点匹配成功，重置Go扫描状态",
        "pre_delay": 0,
        "post_delay": 0,
        "action": "Custom",
        "custom_action": "SeizeDeliveryJobsResetScanStateAction",
        "next": [
            "SeizeDeliveryJobsPressEscAfterMatch"
        ]
    },
    "SeizeDeliveryJobsPressEscAfterMatch": {
        "desc": "终点匹配后按ESC关闭地图",
        "action": "ClickKey",
        "key": 27,
        "post_delay": 1000,
        "next": [
            "SeizeDeliveryJobsAcceptClick"
        ]
    },
    "SeizeDeliveryJobsAcceptClick": {
        "desc": "点击接取运送委托（由Go覆写target）",
        "action": "Click",
        "post_wait_freezes": {
            "time": 2000,
            "target": [
                2,
                164,
                264,
                103
            ]
        },
        "next": [
            "isSeizeDeliveryJobsInWorldAfterAccept",
            "SeizeDeliveryJobsRetryClickAccept"
        ]
    },
    "SeizeDeliveryJobsEndpointNotMatched": {
        "desc": "终点未匹配，继续扫描下一个委托",
        "focus": {
            "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.endpointNotMatched"
        },
        "next": [
            "SeizeDeliveryJobsPressEscAfterNotMatch"
        ]
    },
    "SeizeDeliveryJobsPressEscAfterNotMatch": {
        "desc": "终点未匹配后按ESC关闭地图",
        "action": "ClickKey",
        "key": 27,
        "post_delay": 1000,
        "next": [
            "SeizeDeliveryJobsScanTarget"
        ]
    },
    "SeizeDeliveryJobsScanExhausted": {
        "desc": "扫描完毕未找到目标委托，重置Go扫描状态",
        "action": "Custom",
        "custom_action": "SeizeDeliveryJobsResetScanStateAction",
        "next": [
            "SeizeDeliveryJobsRefresh"
        ]
    }
