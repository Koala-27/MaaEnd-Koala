{
    "AutoCollectSchedule": {
        "desc": "自动采集时间任务",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "AutoCollectScheduleEnabled",
            "AutoCollectEnd"
        ]
    },
    "AutoCollectScheduleEnabled": {
        "desc": "自动采集时间任务命中",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ScheduleRecognition",
                "custom_recognition_param": {}
            }
        },
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "AutoCollectResetFailures"
        ],
        "attach": {
            "monday": false,
            "tuesday": false,
            "wednesday": false,
            "thursday": false,
            "friday": false,
            "saturday": false,
            "sunday": false
        }
    },
    "AutoCollectResetFailures": {
        "desc": "重置自动采集路线执行结果",
        "action": "Custom",
        "custom_action": "FailureCollectorReset",
        "custom_action_param": {
            "key": "AutoCollect"
        },
        "next": [
            "AutoCollectBeforeStashBackpack"
        ]
    },
    "AutoCollectBeforeStashBackpack": {
        "desc": "自动采集前存放背包",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "SubTask",
        "custom_action_param": {
            "sub": [
                "StashBackpackSubTask"
            ]
        },
        "post_delay": 0,
        "next": [
            "AutoCollectLoop"
        ]
    },
    "AutoCollectLoop": {
        "desc": "依次执行已启用的自动采集路线",
        "next": [
            "[JumpBack]AutoCollectRoute1Sub",
            "[JumpBack]AutoCollectRoute2Sub",
            "[JumpBack]AutoCollectRoute3Sub",
            "[JumpBack]AutoCollectRoute4Sub",
            "[JumpBack]AutoCollectRoute5Sub",
