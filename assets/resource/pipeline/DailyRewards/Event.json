{
    "DailyEventStart": {
        "desc": "每日奖励活动入口",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "DailyEventEnterMenu",
            "[JumpBack]SceneEnterMenuEvent"
        ]
    },
    "DailyEventEnterMenu": {
        "desc": "进入活动界面",
        "recognition": "And",
        "all_of": [
            "InEventCenter"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "DailyEventUnreadItemInit",
            "DailyEventFinish"
        ]
    },
    "DailyEventUnreadItemInit": {
        "desc": "初始化未读活动",
        "recognition": "Custom",
        "custom_recognition": "DailyEventUnreadItemInitRecognition",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "DailyEventUnreadItemInitAction",
        "post_delay": 0
    },
    "DailyEventUnreadItemSwitch": {
        "desc": "切换未处理的活动列表",
        "recognition": "OCR",
        "roi": [
            36,
            110,
            166,
            40
        ],
        "expected": [
            ".{3,}" // 匹配三个及以上字符
        ],
        "only_rec": true,
        "pre_delay": 0,
        "action": "Click",
        "target_offset": [
            40,
            0,
            0,
            0
        ],
        "next": [
            "DailyEventUnreadItemSwitchSuccess"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "切换活动"
        }
    },
    "DailyEventUnreadItemSwitchSuccess": {
        "desc": "切换活动成功",
        "recognition": "And",
        "all_of": [
            {
                "recognition": "TemplateMatch",
                "roi": "DailyEventUnreadItemSwitch",
                "roi_offset": [
                    -20,
                    -30,
                    20,
                    40
                ],
                "template": "DailyRewards/Event/EventSwitchSuccess.png",
                "threshold": 0.9
            },
            {
                "recognition": "TemplateMatch",
                "roi": [
                    -200,
                    0,
                    200,
                    200
                ],
                "template": "DailyRewards/Event/EventDetailsIcon.png",
                "green_mask": true
            }
        ],
        "box_index": 1,
        "pre_wait_freezes": 100,
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "DailyEventUnreadLimitedTimeSignin",
            "DailyEventUnreadWeeklyRoutine",
            "DailyEventUnreadGuideEvent",
            "DailyEventUnreadChallengeEvent",
            "DailyEventUnreadSpaceExplorationEvent",
            "DailyEventUnreadLimitedTimeEvent",
            "DailyEventUnreadUnknown"
        ]
    },
    "DailyEventUnreadUnknown": {
        "desc": "跳过未支持的活动",
        "pre_delay": 0,
        "post_delay": 0,
        "focus": {
            "Node.Recognition.Succeeded": "跳过未支持的活动"
        }
    },
    "DailyEventFinish": {
        "desc": "结束任务",
        "focus": {
            "Node.Recognition.Succeeded": "领取活动奖励结束"
        }
    },
    "DailyEventRecognitionRedDot": {
        "desc": "识别活动界面的红点",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    0,
                    300,
                    720
                ],
                "template": [
                    "DailyRewards/EventRedDot.png",
                    "DailyRewards/EventRedDot2.png",
                    "DailyRewards/EventRedDot3.png",
                    "DailyRewards/EventRedDot4.png"
                ],
                "green_mask": true
            }
        }
    },
    "DailyEventRecognitionGotoButton": {
        "desc": "识别活动界面是前往按钮",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "前往",
                    "Go",
                    "移動",
                    "바로가기"
                ]
            }
        }
    },
    "DailyEventRecognitionItemText": {
        "desc": "识别活动界面的红点",
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    ".{3,}" // 匹配三个及以上字符
                ],
                "threshold": 0.7
            }
        }
    }
}
