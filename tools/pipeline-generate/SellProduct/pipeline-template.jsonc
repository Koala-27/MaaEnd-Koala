        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProductSellLoop"
        ]
    },
    "SellProduct${LocationId}OpenTargetOperatorList": {
        "desc": "${LocationDesc}打开派驻干员列表以切换售卖用干员",
        "recognition": "And",
        "all_of": [
            "SellProductIn${LocationId}"
        ],
        "pre_delay": 0,
        "action": "Click",
        "target": [
            250,
            570,
            30,
            30
        ],
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}InTargetOperatorList"
        ]
    },
    "SellProduct${LocationId}InTargetOperatorList": {
