{
    // ===== 售卖点顶层节点 =====
    "SellProduct${LocationId}": {
        "desc": "${LocationDesc}售卖",
        "max_hit": 1,
        "recognition": "And",
        "all_of": [
            "SellProductCheck${LocationId}TabText"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}Sell",
            "[JumpBack]SellProductGoTo${LocationId}"
        ]
    },
    // ===== 售卖锚点节点 =====
    "SellProduct${LocationId}Sell": {
        "desc": "${LocationDesc}售卖",
        "recognition": "And",
        "all_of": [
            "SellProductIn${LocationId}"
        ],
        "pre_delay": 0,
        "anchor": {
            "SellProductZeroMoneyHandler": "SellProductZeroMoneyWithTip",
            "SellProductSelectGoodFirstTime": "SellProductSelectFirstGood",
            "SellProductSellAttempt1": "SellProduct${LocationId}SellAttempt1",
            "SellProductSellAttempt2": "SellProduct${LocationId}SellAttempt2",
            "SellProductSellAttempt3": "SellProduct${LocationId}SellAttempt3",
            "SellProductSellAttempt4": "SellProduct${LocationId}SellAttempt4"
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}SetBeforeSellOperatorAnchor"
        ]
    },
    "SellProduct${LocationId}SetBeforeSellOperatorAnchor": {
        "desc": "${LocationDesc}设置售卖前派驻干员锚点",
        "anchor": {
            "SellProductBeforeSellOperator": ""
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}SetAfterSellOperatorAnchor"
        ]
    },
    "SellProduct${LocationId}SetAfterSellOperatorAnchor": {
        "desc": "${LocationDesc}设置售卖后恢复干员锚点",
        "anchor": {
            "SellProductAfterSellOperator": ""
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "[Anchor]SellProductBeforeSellOperator",
            "SellProductSellLoop"
        ]
    },
    // ===== 售卖前派驻干员切换 =====
    "SellProduct${LocationId}BeforeSellOperator": {
        "desc": "${LocationDesc}售卖前检查并切换派驻干员",
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}CurrentTargetOperator",
            "SellProduct${LocationId}OpenTargetOperatorList"
        ]
    },
    "SellProduct${LocationId}CurrentTargetOperator": {
        "desc": "${LocationDesc}当前派驻干员已是售卖用干员",
        "recognition": "OCR",
        "roi": [
            268,
            568,
            190,
            35
        ],
        "expected": [],
